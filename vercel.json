{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-server run build",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "api/index.mjs",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.mjs"
    }
  ]
}
